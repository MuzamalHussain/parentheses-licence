# Copy to .env for local development. Use placeholder values here only.

# App
NODE_ENV=development
APP_ENV=development
DEPLOYMENT_TARGET=local
PORT=5000
CLIENT_URL=http://localhost:5173

# Database - required
# Atlas example:
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/<database>?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=parentheses_licensing
# Optional comma-separated DNS resolvers for Atlas SRV lookup issues on some Windows networks.
DNS_SERVERS=

# Auth - required, generate unique secrets per environment.
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_random_access_secret
JWT_REFRESH_SECRET=replace_with_random_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
JWT_ISSUER=parentheses-licensing
JWT_AUDIENCE=parentheses-licensing-users
AUTH_MAX_FAILED_LOGIN_ATTEMPTS=5
AUTH_LOGIN_LOCKOUT_MINUTES=15
AUTH_MAX_REFRESH_SESSIONS=5

# Optional Redis rate-limit backing store.
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379

# API security limits.
API_JSON_BODY_LIMIT=1mb
API_URLENCODED_BODY_LIMIT=256kb
API_WEBHOOK_BODY_LIMIT=256kb
API_RATE_GLOBAL_WINDOW_MS=900000
API_RATE_GLOBAL_MAX=300
API_RATE_AUTH_WINDOW_MS=900000
API_RATE_AUTH_MAX=10
API_RATE_DOWNLOAD_WINDOW_MS=60000
API_RATE_DOWNLOAD_MAX=30
API_RATE_WEBHOOK_WINDOW_MS=60000
API_RATE_WEBHOOK_MAX=120
API_RATE_ADMIN_WINDOW_MS=60000
API_RATE_ADMIN_MAX=180
WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300

# Performance and scalability.
API_PAGINATION_DEFAULT_LIMIT=20
API_PAGINATION_MAX_LIMIT=100
API_CUSTOMER_PAGINATION_MAX_LIMIT=50
DASHBOARD_CACHE_TTL_MS=30000
STATS_CACHE_TTL_MS=30000
SLOW_REQUEST_THRESHOLD_MS=750
MEMORY_LOG_HEAP_MB=256

# Email - optional in local development. Required for real verification/reset email delivery.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Parentheses Solutions <no-reply@example.com>"
SMTP_REPLY_TO=
EMAIL_PROVIDER=smtp
EMAIL_ENABLED=false
EMAIL_RETRY_COUNT=2
EMAIL_TIMEOUT_MS=10000
STARTUP_VERIFY_SMTP=false

# Stripe - required only when testing Stripe checkout/webhooks.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Local PSP - placeholder adapter values until a real provider is selected.
LOCAL_PSP_BASE_URL=https://sandbox.local-psp.example.com/api/v1
LOCAL_PSP_MERCHANT_ID=dummy_merchant_id
LOCAL_PSP_SECRET_KEY=dummy_secret_key_replace_me

# Operational resilience.
STORAGE_PROVIDER=local
UPLOAD_ROOT=uploads
BACKUP_ROOT=backups
CONFIG_BACKUP_INCLUDE_ENV=false
BACKUP_READINESS_STRICT=false
MAINTENANCE_MODE=false
READ_ONLY_MODE=false
EMERGENCY_SHUTDOWN=false

# Feature flags - read-only in Phase 7A. Defaults preserve current behavior.
ENABLE_STRIPE=true
ENABLE_LOCAL_PSP=true
ENABLE_EMAIL_VERIFICATION_ENFORCEMENT=true
ENABLE_WORDPRESS_UPDATER=true
ENABLE_PLUGIN_UPLOAD_SECURITY_STRICT=false
ENABLE_ADVANCED_SESSION_SECURITY=false
ENABLE_WEBHOOK_STRICT_IDEMPOTENCY=false
ENABLE_PAYMENT_TRANSACTIONS=false
ENABLE_LICENSE_ACTIVATION_ATOMIC_GUARD=false

# Plugin ZIP upload security limits.
PLUGIN_ZIP_MAX_UPLOAD_MB=50
PLUGIN_ZIP_MAX_UNCOMPRESSED_MB=150
PLUGIN_ZIP_MAX_FILES=2000
PLUGIN_ZIP_MAX_COMPRESSION_RATIO=20

# License engine hardening.
LICENSE_ALLOW_LOCALHOST=true
LICENSE_ALLOW_PRIVATE_HOSTS=true
LICENSE_ALLOW_STAGING_DOMAINS=true
LICENSE_GRACE_PERIOD_DAYS=0
LICENSE_DOWNLOAD_TOKEN_TTL_MS=600000
LICENSE_UPDATER_TOKEN_TTL_MS=600000
LICENSE_KEY_SEGMENTS=4
LICENSE_KEY_SEGMENT_LENGTH=4
LICENSE_KEY_CHECKSUM=false
# Required to save secrets in Integrations Center (minimum 32 characters)
APP_ENCRYPTION_KEY=
