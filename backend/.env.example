# Copy to .env for local development. Use placeholder values here only.

# App
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# Database - required
# Atlas example:
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/<database>?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=parentheses_licensing
# Optional comma-separated DNS resolvers for Atlas SRV lookup issues on some Windows networks.
DNS_SERVERS=

# Auth - required, generate unique secrets per environment.
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_random_access_secret
JWT_REFRESH_SECRET=replace_with_random_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
JWT_ISSUER=parentheses-licensing
JWT_AUDIENCE=parentheses-licensing-users
AUTH_MAX_FAILED_LOGIN_ATTEMPTS=5
AUTH_LOGIN_LOCKOUT_MINUTES=15
AUTH_MAX_REFRESH_SESSIONS=5

# Optional Redis rate-limit backing store.
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379

# Email - optional in local development. Required for real verification/reset email delivery.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Parentheses Solutions <no-reply@example.com>"
SMTP_REPLY_TO=
EMAIL_PROVIDER=smtp
EMAIL_RETRY_COUNT=2
EMAIL_TIMEOUT_MS=10000

# Stripe - required only when testing Stripe checkout/webhooks.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Local PSP - placeholder adapter values until a real provider is selected.
LOCAL_PSP_BASE_URL=https://sandbox.local-psp.example.com/api/v1
LOCAL_PSP_MERCHANT_ID=dummy_merchant_id
LOCAL_PSP_SECRET_KEY=dummy_secret_key_replace_me

# Feature flags - read-only in Phase 7A. Defaults preserve current behavior.
ENABLE_STRIPE=true
ENABLE_LOCAL_PSP=true
ENABLE_EMAIL_VERIFICATION_ENFORCEMENT=true
ENABLE_WORDPRESS_UPDATER=true
ENABLE_PLUGIN_UPLOAD_SECURITY_STRICT=false
ENABLE_ADVANCED_SESSION_SECURITY=false
ENABLE_WEBHOOK_STRICT_IDEMPOTENCY=false
ENABLE_PAYMENT_TRANSACTIONS=false
ENABLE_LICENSE_ACTIVATION_ATOMIC_GUARD=false

# Plugin ZIP upload security limits.
PLUGIN_ZIP_MAX_UPLOAD_MB=50
PLUGIN_ZIP_MAX_UNCOMPRESSED_MB=150
PLUGIN_ZIP_MAX_FILES=2000
PLUGIN_ZIP_MAX_COMPRESSION_RATIO=20
