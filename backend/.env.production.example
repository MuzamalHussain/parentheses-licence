# Production template. Never commit real values.

NODE_ENV=production
PORT=5000
CLIENT_URL=https://app.example.com

# Database - required. Use a production MongoDB Atlas cluster.
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/<database>?retryWrites=true&w=majority
MONGO_DB_NAME=parentheses_licensing
DNS_SERVERS=

# Auth - required. Generate fresh, unique secrets for production.
JWT_ACCESS_SECRET=replace_with_random_access_secret
JWT_REFRESH_SECRET=replace_with_random_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
JWT_ISSUER=parentheses-licensing
JWT_AUDIENCE=parentheses-licensing-users
AUTH_MAX_FAILED_LOGIN_ATTEMPTS=5
AUTH_LOGIN_LOCKOUT_MINUTES=15
AUTH_MAX_REFRESH_SESSIONS=5

# Redis - recommended in production.
REDIS_ENABLED=true
REDIS_URL=redis://<redis-host>:6379

# Email - required for verification and password reset flows.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASS=replace_with_smtp_password
SMTP_FROM="Parentheses Solutions <no-reply@example.com>"
SMTP_REPLY_TO=support@example.com
EMAIL_PROVIDER=smtp
EMAIL_RETRY_COUNT=2
EMAIL_TIMEOUT_MS=10000

# Stripe - required for Stripe checkout/webhooks.
STRIPE_SECRET_KEY=sk_live_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Local PSP - replace with provider credentials after provider selection.
LOCAL_PSP_BASE_URL=https://provider.example.com/api/v1
LOCAL_PSP_MERCHANT_ID=replace_with_merchant_id
LOCAL_PSP_SECRET_KEY=replace_with_psp_secret

# Feature flags - read-only in Phase 7A. Defaults preserve current behavior.
ENABLE_STRIPE=true
ENABLE_LOCAL_PSP=true
ENABLE_EMAIL_VERIFICATION_ENFORCEMENT=true
ENABLE_WORDPRESS_UPDATER=true
ENABLE_PLUGIN_UPLOAD_SECURITY_STRICT=true
ENABLE_ADVANCED_SESSION_SECURITY=false
ENABLE_WEBHOOK_STRICT_IDEMPOTENCY=false
ENABLE_PAYMENT_TRANSACTIONS=false
ENABLE_LICENSE_ACTIVATION_ATOMIC_GUARD=false

# Plugin ZIP upload security limits.
PLUGIN_ZIP_MAX_UPLOAD_MB=50
PLUGIN_ZIP_MAX_UNCOMPRESSED_MB=150
PLUGIN_ZIP_MAX_FILES=2000
PLUGIN_ZIP_MAX_COMPRESSION_RATIO=20
